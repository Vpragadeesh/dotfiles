#!/usr/bin/env sh
set -eu

SESSION_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/nirinit/session.json"
LAUNCHER_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/nirinit-launchers"

mkdir -p "$LAUNCHER_DIR"

# Clean generated wrappers from previous runs.
find "$LAUNCHER_DIR" -maxdepth 1 -type f -delete

[ -f "$SESSION_FILE" ] || exit 0

jq -r '.[].launch_command // empty' "$SESSION_FILE" | sort -u | while IFS= read -r cmd; do
    [ -n "$cmd" ] || continue

    # Only generate safe file names.
    case "$cmd" in
        *[!A-Za-z0-9._+-]*)
            continue
            ;;
    esac

    launcher="$LAUNCHER_DIR/$cmd"
    lower_cmd=$(printf '%s' "$cmd" | tr '[:upper:]' '[:lower:]')

    cat > "$launcher" <<EOF
#!/usr/bin/env sh
set -eu

cmd="$cmd"
lower="$lower_cmd"
EOF
    printf '%s\n' 'lower_browser="${lower}-browser"' >> "$launcher"
    printf '%s\n' 'cmd_browser="${cmd}-browser"' >> "$launcher"
    cat >> "$launcher" <<'EOF'

# Known app-id to binary mappings for common Niri sessions.
if [ "$cmd" = "Code" ] && [ -x "/usr/bin/code" ]; then
    exec /usr/bin/code --new-window
fi

if [ "$cmd" = "zen" ] && command -v zen-browser >/dev/null 2>&1; then
    exec zen-browser "$@"
fi

if [ "$cmd" = "org.wezfurlong.wezterm" ] && command -v wezterm >/dev/null 2>&1; then
    exec wezterm "$@"
fi

if [ "$cmd" = "org.qutebrowser.qutebrowser" ] && command -v qutebrowser >/dev/null 2>&1; then
    exec qutebrowser "$@"
fi

if command -v gtk-launch >/dev/null 2>&1; then
    if gtk-launch "$cmd" >/dev/null 2>&1; then
        exit 0
    fi
fi

if command -v "$cmd" >/dev/null 2>&1; then
    exec "$cmd" "$@"
fi

if [ "$lower" != "$cmd" ] && command -v "$lower" >/dev/null 2>&1; then
    exec "$lower" "$@"
fi

if command -v "$lower_browser" >/dev/null 2>&1; then
    exec "$lower_browser" "$@"
fi

if command -v "$cmd_browser" >/dev/null 2>&1; then
    exec "$cmd_browser" "$@"
fi

if command -v flatpak >/dev/null 2>&1; then
    exec flatpak run "$cmd"
fi

exit 127
EOF

    chmod +x "$launcher"
done
